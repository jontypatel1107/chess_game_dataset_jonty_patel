{
  "name": "chess-backend",
  "version": "1.0.0",
  "description": "Full-featured Chess Game REST API built with Node.js, Express.js, and MongoDB Atlas",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "import:data": "node importDataset.js",
    "build": "cd ../chess-frontend && npm install && npm run build",
    "postinstall": "npm run build"
  },
  "keywords": ["chess", "nodejs", "express", "mongodb", "rest-api"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.3.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
